{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "fskin",
  "colors": {
    "primary": "#6663f1",
    "light": "#6663f1",
    "dark": "#6663f1"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Dashboard",
        "pages": [
          "dashboard/overview",
          "dashboard/account",
          "dashboard/teams",
          "dashboard/projects",
          "dashboard/skins"
        ]
      },
      {
        "group": "Package",
        "pages": [
          "package/installation",
          "package/implementation",
          "package/contribute"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Package",
          "href": "https://pub.dev/packages/flutter_skin",
